# Copy to ~/.personal-agent/.env and fill in from your Upwork app
# (https://www.upwork.com/developer). The app does not read a repo-local .env.

UPWORK_KEY=your_oauth2_client_id
UPWORK_SECRET=your_oauth2_client_secret

# The redirect URI MUST match one registered on your Upwork app.
# This app spins up a local server on PORT and uses http://localhost:PORT/callback
REDIRECT_URI=http://localhost:3000/callback
PORT=3000

# Dashboard server. Bind to 0.0.0.0 for Tailscale access.
# DASHBOARD_SECRET is required. Generate one with: openssl rand -hex 32
DASHBOARD_SECRET=replace_with_a_long_random_secret
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5173
DASHBOARD_PUBLIC_HOST=studio.tailcc4c77.ts.net

# Optional PI goal-assistant overrides. The assistant only receives the
# read-only read, grep, find, and ls tools inside the selected project path.
PI_GOAL_ASSISTANT_MODEL=zai/glm-5.2
PI_GOAL_ASSISTANT_THINKING=low
PI_GOAL_ASSISTANT_TIMEOUT_MS=180000
