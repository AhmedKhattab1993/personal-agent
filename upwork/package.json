{
  "name": "upwork-agent",
  "version": "0.1.0",
  "description": "Upwork OAuth2 client + GraphQL helper for fetching job postings",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "auth": "node src/auth.js",
    "dashboard": "node src/dashboardServer.js",
    "dashboard:build": "vite build --config dashboard/vite.config.js",
    "dashboard:reclassify": "node src/reclassifyDashboardJobs.js",
    "jobs": "node src/fetchJobs.js 1000",
    "jobs:sample": "node src/fetchJobs.js 10",
    "me": "node src/me.js",
    "proposals": "node src/fetchProposalHistory.js",
    "test": "node --test src/*.test.js dashboard/src/*.test.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.1"
  }
}
